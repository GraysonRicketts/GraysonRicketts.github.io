---
import { getCollection } from 'astro:content';
import Base from '@layouts/Base.astro';
import ArticleCard from '@components/ArticleCard.astro';

const articles = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Base
  title="Writing — Grayson Ricketts"
  description="Articles and essays on software engineering, design, and the craft of building things."
>
  <div class="max-w-6xl mx-auto px-6 py-16">
    <header class="mb-12">
      <p class="text-sm font-medium text-orange-500 dark:text-orange-400 uppercase tracking-widest mb-3">
        Writing
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">
        Writing
      </h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-xl">
        Articles and essays on software engineering, design, and the craft of building things.
      </p>
    </header>

    {articles.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">Nothing published yet. Check back soon.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {articles.map((a) => (
          <ArticleCard
            title={a.data.title}
            description={a.data.description}
            slug={a.slug}
            publishDate={a.data.publishDate}
            tags={a.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</Base>
