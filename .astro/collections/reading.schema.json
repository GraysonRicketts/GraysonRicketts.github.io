{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "author": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "dateAdded": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "url",
    "dateAdded",
    "tags"
  ],
  "additionalProperties": false
}