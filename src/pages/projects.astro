---
import { getCollection } from 'astro:content';
import Base from '@layouts/Base.astro';
import ProjectCard from '@components/ProjectCard.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Projects — Grayson Ricketts"
  description="Things I've built — apps, tools, and experiments."
>
  <div class="max-w-6xl mx-auto px-6 py-16">
    <header class="mb-12">
      <p class="text-sm font-medium text-orange-500 dark:text-orange-400 uppercase tracking-widest mb-3">
        Work
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">
        Projects
      </h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-xl">
        Things I've built — apps, tools, and experiments.
      </p>
    </header>

    {projects.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">No projects yet. Check back soon.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {projects.map((p) => (
          <ProjectCard
            title={p.data.title}
            description={p.data.description}
            url={p.data.url}
            repoUrl={p.data.repoUrl}
          />
        ))}
      </div>
    )}
  </div>
</Base>
