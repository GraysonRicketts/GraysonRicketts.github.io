---
// ThemeToggle — sun/moon button that persists to localStorage
---

<button
  id="theme-toggle"
  aria-label="Toggle dark mode"
  class="p-2 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
>
  <!-- Sun icon (shown in dark mode → click to go light) -->
  <svg
    id="icon-sun"
    class="w-4 h-4 hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>

  <!-- Moon icon (shown in light mode → click to go dark) -->
  <svg
    id="icon-moon"
    class="w-4 h-4"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle')!;
  const root = document.documentElement;
  const sun = document.getElementById('icon-sun')!;
  const moon = document.getElementById('icon-moon')!;

  function syncIcons() {
    const isDark = root.classList.contains('dark');
    sun.classList.toggle('hidden', !isDark);
    moon.classList.toggle('hidden', isDark);
    btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
  }

  btn.addEventListener('click', () => {
    root.classList.toggle('dark');
    localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
    syncIcons();
  });

  // Sync on load in case inline script ran before this
  syncIcons();
</script>
