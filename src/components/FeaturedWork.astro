---
import ArticleCard from './ArticleCard.astro';
import ProjectCard from './ProjectCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  articles: CollectionEntry<'writing'>[];
  projects: CollectionEntry<'projects'>[];
}

const { articles, projects } = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 pb-20">
  <div class="border-t border-zinc-200 dark:border-zinc-800 pt-16">

    {projects.length > 0 && (
      <div class="mb-16">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-sm font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-widest">
            Featured Projects
          </h2>
          <a
            href="/projects"
            class="text-sm text-zinc-500 dark:text-zinc-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors flex items-center gap-1"
          >
            All projects
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {projects.map((p) => (
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              url={p.data.url}
              repoUrl={p.data.repoUrl}
              tags={p.data.tags}
            />
          ))}
        </div>
      </div>
    )}

    {articles.length > 0 && (
      <div>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-sm font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-widest">
            Recent Writing
          </h2>
          <a
            href="/writing"
            class="text-sm text-zinc-500 dark:text-zinc-400 hover:text-orange-500 dark:hover:text-orange-400 transition-colors flex items-center gap-1"
          >
            All posts
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {articles.map((a) => (
            <ArticleCard
              title={a.data.title}
              description={a.data.description}
              slug={a.id.replace(/\.(mdx?)$/, '')}
              publishDate={a.data.publishDate}
              tags={a.data.tags}
            />
          ))}
        </div>
      </div>
    )}

  </div>
</section>
