---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/projects', label: 'Projects' },
  { href: '/writing', label: 'Writing' },
  { href: '/reading', label: 'Reading' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-zinc-50/80 dark:bg-zinc-950/80 backdrop-blur-sm border-b border-zinc-200 dark:border-zinc-800">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between gap-6">

    <!-- Logo / Name -->
    <a
      href="/"
      class="font-bold text-base tracking-tight text-zinc-900 dark:text-zinc-100 hover:text-orange-500 dark:hover:text-orange-400 transition-colors shrink-0"
    >
      Grayson Ricketts
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-7">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm font-medium transition-colors ${
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-orange-500 dark:text-orange-400'
              : 'text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100'
          }`}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Right: social + resume + toggle -->
    <div class="flex items-center gap-2">
      <!-- X (Twitter) -->
      <a
        href="https://x.com/GraysonRicketts"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="X (Twitter)"
        class="p-2 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://linkedin.com/in/grayson-ricketts"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="p-2 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <!-- Resume download -->
      <a
        href="/resume.pdf"
        download
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium px-3 py-1.5 rounded-lg border border-orange-500 dark:border-orange-400 text-orange-500 dark:text-orange-400 hover:bg-orange-500 dark:hover:bg-orange-400 hover:text-white dark:hover:text-zinc-950 transition-colors ml-1"
      >
        Resume
      </a>

      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        class="md:hidden p-2 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
      >
        <svg id="icon-menu" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav dropdown -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950"
  >
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm font-medium px-3 py-2 rounded-lg transition-colors ${
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-orange-500 dark:text-orange-400 bg-orange-500/10'
              : 'text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800'
          }`}
        >
          {label}
        </a>
      ))}
      <a
        href="/resume.pdf"
        download
        class="text-sm font-medium px-3 py-2 rounded-lg text-orange-500 dark:text-orange-400 hover:bg-orange-500/10 transition-colors mt-1"
      >
        Download Resume
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconMenu.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
