---
interface Props {
  title: string;
  description: string;
  url: string;
  repoUrl?: string;
}

const { title, description, url, repoUrl } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6 transition-all duration-200 hover:shadow-glow-orange hover:border-orange-500/40 dark:hover:border-orange-400/40"
>
  <div class="flex items-start justify-between mb-3 gap-3">
    <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-orange-500 dark:group-hover:text-orange-400 transition-colors leading-snug">
      {title}
    </h3>
    <svg
      class="w-4 h-4 text-zinc-400 group-hover:text-orange-500 dark:group-hover:text-orange-400 transition-colors shrink-0 mt-0.5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
      <polyline points="15 3 21 3 21 9"/>
      <line x1="10" y1="14" x2="21" y2="3"/>
    </svg>
  </div>

  <p class="text-sm text-zinc-600 dark:text-zinc-400 flex-1 mb-4 leading-relaxed">
    {description}
  </p>
</a>
