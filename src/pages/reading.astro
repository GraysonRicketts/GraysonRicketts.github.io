---
import { getCollection } from 'astro:content';
import Base from '@layouts/Base.astro';
import ReadingCard from '@components/ReadingCard.astro';

const links = (await getCollection('reading'))
  .sort((a, b) => b.data.dateAdded.valueOf() - a.data.dateAdded.valueOf());
---

<Base
  title="Reading — Grayson Ricketts"
  description="Articles, essays, and books I've found worth reading."
>
  <div class="max-w-6xl mx-auto px-6 py-16">
    <header class="mb-12">
      <p class="text-sm font-medium text-orange-500 dark:text-orange-400 uppercase tracking-widest mb-3">
        Reading List
      </p>
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4">
        Reading
      </h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-xl">
        Articles, essays, and books I've found worth reading — mostly about software,
        design, and ideas.
      </p>
    </header>

    {links.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">Nothing here yet.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {links.map((item) => (
          <ReadingCard
            title={item.data.title}
            url={item.data.url}
            author={item.data.author}
            source={item.data.source}
            description={item.data.description}
            tags={item.data.tags}
          />
        ))}
      </div>
    )}
  </div>
</Base>
