---
interface Props {
  title: string;
  description: string;
  slug: string;
  publishDate: Date;
  tags: string[];
}

const { title, description, slug, publishDate, tags } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a
  href={`/writing/${slug}`}
  class="group flex flex-col rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6 transition-all duration-200 hover:shadow-glow-orange hover:border-orange-500/40 dark:hover:border-orange-400/40"
>
  <div class="flex items-start justify-between mb-3 gap-3">
    <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-orange-500 dark:group-hover:text-orange-400 transition-colors leading-snug">
      {title}
    </h3>
    <svg
      class="w-4 h-4 text-zinc-400 group-hover:text-orange-500 dark:group-hover:text-orange-400 transition-colors shrink-0 mt-0.5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12"/>
      <polyline points="12 5 19 12 12 19"/>
    </svg>
  </div>

  <p class="text-sm text-zinc-600 dark:text-zinc-400 flex-1 mb-4 leading-relaxed">
    {description}
  </p>

  <div class="flex items-center justify-between gap-3">
    <div class="flex flex-wrap gap-1.5">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-0.5 rounded-md bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 font-medium">
          {tag}
        </span>
      ))}
    </div>
    <time
      datetime={publishDate.toISOString()}
      class="text-xs text-zinc-500 dark:text-zinc-500 shrink-0"
    >
      {formattedDate}
    </time>
  </div>
</a>
